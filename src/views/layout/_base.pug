block variables
  - title = title || '';
  - description = description || 'A modular frontend tooling ecosystem with build system, runtime, UI components and CLI.';
  - canonical = canonical || 'https://razerspine-dev.vercel.app';

doctype html
html(lang='en' dir='ltr' data-theme='dark')
  head
    //- Meta
    meta(charset='utf-8')
    meta(name='viewport' content='width=device-width, initial-scale=1')
    meta(http-equiv='Content-Security-Policy' content='upgrade-insecure-requests')
    meta(name='robots' content='index, follow')
    meta(name='theme-color' content='#0f172a')
    meta(name='description' content=description)
    link(rel='canonical' href=canonical)
    meta(property='og:title' content=title)
    meta(property='og:description' content=description)
    meta(property='og:url' content=canonical)
    meta(property='og:type' content='website')
    meta(property='og:image' content='https://razerspine-dev.vercel.app/og-image.png')
    meta(name='twitter:title' content=title)
    meta(name='twitter:description' content=description)
    meta(name='twitter:image' content='https://razerspine-dev.vercel.app/og-image.png')

    //- Using favicon generator
    link(rel='icon' type='image/png' href=require('@images/favicons/favicon-96x96.png') sizes='96x96')
    link(rel='shortcut icon' href=require('@images/favicons/favicon.ico'))
    link(rel='apple-touch-icon' sizes='180x180' href=require('@images/favicons/apple-touch-icon.png'))
    link(rel='icon' type='image/png' sizes='192x192' href=require('@images/favicons/android-chrome-192x192.png'))
    link(rel='icon' type='image/png' sizes='512x512' href=require('@images/favicons/android-chrome-512x512.png'))

    //- Page title
    title= title

    //- Page specific styles
    block style

    //- Additional head block to add here page specifically assets
    block head

  body#app-root.layout-simple
    //- Body content
    block body

    //- Page specific scripts
    block script
