extends @views/layout/index.pug

block variables
  - title = '404 - Page not found'
  - description = 'The requested page could not be found. Explore Razerspine frontend ecosystem including CLI, runtime, templates and build system.'
  - canonical = 'https://razerspine-dev.vercel.app/404'

block content
  section.section(data-animate='fade-up' data-animate-delay='100')
    h1.title-h1 404
    h2.title-h3.m-b-3 Page Not Found
    a.btn.btn--outline.btn--large(href='index.html') Back to main
