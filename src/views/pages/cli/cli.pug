extends @views/layout/index.pug
include @views/mixins/code.pug

block variables
  - title = 'CLI - Frontend tooling ecosystem';

append style
  link(rel='stylesheet' href='./style.scss')

block content

  section.section.m-b-4
    .container(data-animate='fade-down' data-animate-delay='200')
      h1.title-h1.m-b-2.text-gradient-deep.text-center CLI
      p.title-h5.slate-500.text-center.m-b-4
        | Project scaffolding tool for creating ready-to-use applications
      p.description.m-b-1
        | The CLI is the entry point for creating projects within this frontend tooling ecosystem.
        | It provides a fast and consistent way to scaffold applications using preconfigured templates.
        | You can choose between SPA and MPA architectures, select styling and scripting options,
        | and integrate your preferred package manager.
      p.description
        | The tool supports both interactive and non-interactive modes, making it suitable for local development and CI environments.
        | Generated projects are fully standalone, production-ready, and require no additional setup.
        | The CLI focuses on simplicity, flexibility, and predictable project structure.

  section.section.m-b-4
    .container(data-animate='fade-up' data-animate-delay='200')
      h2.title-h2.m-b-4 Quick Start
      .card
        +code('bash', 'Terminal', true)
          | npx @razerspine/create-app my-app

  section.section.m-b-4
    .container(data-animate='fade-right' data-animate-delay='200')
      h2.title-h2.m-b-4 Options
      .card
        +code('text', 'CLI Flags', false)
          | --app-type spa | mpa
          | --style scss | less
          | --script js | ts
          | --pm npm | pnpm | yarn | bun
          | --no-install
          | --dry-run

  section.section.m-b-4
    .container(data-animate='fade-left' data-animate-delay='200')
      h2.title-h2.m-b-4 Non-interactive Mode
      .card
        +code('bash', 'CI Usage', true)
          | npx @razerspine/create-app my-app \
          |   --app-type spa \
          |   --style scss \
          |   --script ts \
          |   --no-install

  section.section
    .container(data-animate='fade-up' data-animate-delay='200')
      h2.title-h2.m-b-4 How It Works
      .card
        +code('text', 'Pipeline', false)
          | resolve template → copy files → patch package.json → install
