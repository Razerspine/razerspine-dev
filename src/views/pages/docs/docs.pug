extends @views/layout/index.pug
include @views/mixins/code.pug

block variables
  - title = 'Documentation - Razerspine frontend ecosystem'
  - description = 'Complete documentation for Razerspine ecosystem including CLI, runtime, build system and UI components. Learn architecture, configuration and best practices.'
  - canonical = 'https://razerspine-dev.vercel.app/docs'

block content

  section.section.m-b-4
    .container(data-animate='fade-down' data-animate-delay='200')
      h1.title-h1.m-b-2.text-gradient-deep.text-center Documentation
      p.title-h5.slate-500.text-center.m-b-4
        | Learn how to use each part of the ecosystem to build modern frontend applications
      .description
        p.m-b-1
          | This documentation provides a complete overview of a modular frontend tooling ecosystem
          | designed for building modern web applications without relying on heavy frameworks.
          | It explains how individual packages work together to handle project scaffolding,
          | build configuration, runtime logic, and UI composition.
        p.m-b-1
          | Each part of the system can be used independently, allowing developers to adopt only what they need
          | while maintaining full control over architecture and tooling decisions.
          | The CLI simplifies project creation, templates provide a production-ready foundation,
          | the build system manages bundling and environment configuration,
          | and the runtime enables reactive state, routing, and component lifecycle for SPA applications.
        p.m-b-1
          | The ecosystem supports both SPA and MPA approaches, making it suitable for dynamic applications,
          | static websites, and hybrid solutions.
          | This documentation is structured to help you quickly understand core concepts,
          | explore individual packages, and apply them in real-world projects.

  section.section.m-b-4
    .container(data-animate='fade-up' data-animate-delay='200')
      h2.title-h2.m-b-4 How to Navigate
      .card
        p.title-h5.m-b-2
          | The documentation is organized around the core parts of the ecosystem.
        p.brand-500.m-b-2
          | Start with Getting Started to create your first project,
          | then explore individual packages depending on your needs.

        ul
          li
            strong CLI:
            |  project creation and scaffolding
          li
            strong Templates:
            |  project structure and configuration
          li
            strong Runtime:
            |  application logic, routing and reactivity
          li
            strong Build:
            |  bundling, configuration and deployment

  section.section.m-b-4
    .container
      h2.title-h2.m-b-4 Core Packages

      .row.row--gap-25

        .col-12.col-md-6
          .card.card--space-between(data-animate='fade-right' data-animate-delay='100')
            h3.title-h4.m-b-2.text-gradient-soft CLI
            p.m-b-2
              | Scaffolding tool for generating production-ready projects
              | with predefined templates and smart configuration.

            a.link.btn.btn--outline.btn--medium(href='https://www.npmjs.com/package/@razerspine/create-app' target='_blank' rel='noopener noreferrer')
              | View on npm
              svg.button-icon.icon--icon-small(role='img')
                use(xlink:href='#icon-arrow-next' href='#icon-arrow-next')

        .col-12.col-md-6
          .card.card--space-between(data-animate='fade-left' data-animate-delay='200')
            h3.title-h4.m-b-2.text-gradient-soft Build
            p.m-b-2
              | Webpack abstraction layer with defineConfig API,
              | plugin system and hosting integration.

            a.link.btn.btn--outline.btn--medium(href='https://www.npmjs.com/package/@razerspine/build' target='_blank' rel='noopener noreferrer')
              | View on npm
              svg.button-icon.icon--icon-small(role='img')
                use(xlink:href='#icon-arrow-next' href='#icon-arrow-next')

        .col-12.col-md-6
          .card.card--space-between(data-animate='fade-right' data-animate-delay='300')
            h3.title-h4.m-b-2.text-gradient-soft Runtime
            p.m-b-2
              | Lightweight runtime engine with dependency injection,
              | router, reactivity and template bindings.

            a.link.btn.btn--outline.btn--medium(href='https://www.npmjs.com/package/@razerspine/runtime' target='_blank' rel='noopener noreferrer')
              | View on npm
              svg.button-icon.icon--icon-small(role='img')
                use(xlink:href='#icon-arrow-next' href='#icon-arrow-next')

        .col-12.col-md-6
          .card.card--space-between(data-animate='fade-left' data-animate-delay='400')
            h3.title-h4.m-b-2.text-gradient-soft UI
            p.m-b-2
              | UI layer with compiled CSS, SCSS/LESS sources
              | and Pug component library.

            a.link.btn.btn--outline.btn--medium(href='https://www.npmjs.com/package/@razerspine/ui' target='_blank' rel='noopener noreferrer')
              | View on npm
              svg.button-icon.icon--icon-small(role='img')
                use(xlink:href='#icon-arrow-next' href='#icon-arrow-next')

  section.section.m-b-4
    .container(data-animate='fade-up' data-animate-delay='200')
      h2.title-h2.m-b-4 Architecture

      p.title-h5.m-b-2
        | The ecosystem is built around clear separation of concerns

      .card
        +code('text', 'Text')
          | create-app → build → runtime → ui

  section.section
    .container(data-animate='fade-up' data-animate-delay='200')
      h2.title-h2.m-b-4 Next Steps
      .row.row--gap-25
        .col-12.col-md-4
          .card.card--space-between
            h3.title-h4.m-b-2.text-gradient-soft Getting Started
            p.m-b-2 Learn how to create and run your first project
            a.link.btn.btn--outline.btn--medium(href='/getting-started.html') Read
              svg.button-icon.icon--icon-small(role='img')
                use(xlink:href='#icon-arrow-next' href='#icon-arrow-next')

        .col-12.col-md-4
          .card.card--space-between
            h3.title-h4.m-b-2.text-gradient-soft Examples
            p.m-b-2 Explore real usage examples and templates
            a.link.btn.btn--outline.btn--medium(href='/examples.html') View
              svg.button-icon.icon--icon-small(role='img')
                use(xlink:href='#icon-arrow-next' href='#icon-arrow-next')

        .col-12.col-md-4
          .card.card--space-between
            h3.title-h4.m-b-2.text-gradient-soft GitHub
            p.m-b-2 Browse source code and contribute
            a.link.btn.btn--outline.btn--medium(href='https://github.com/Razerspine/razerspine-stack' target='_blank' rel='noopener noreferrer')
              | Open
              svg.button-icon.icon--icon-small(role='img')
                use(xlink:href='#icon-arrow-next' href='#icon-arrow-next')
