extends @views/layout/index.pug
include @views/mixins/code.pug

block variables
  - title = 'Examples - Frontend tooling ecosystem';

append style
  link(rel='stylesheet' href='./style.scss')

block content
  section.section.m-b-4
    .container(data-animate='fade-down' data-animate-delay='200')
      h1.title-h1.m-b-2.text-gradient-deep.text-center Examples
      p.title-h5.slate-500.text-center.m-b-2
        | Real usage examples of the runtime, templates and build system
      p.title-h5.brand-500.text-center.m-b-4
        | SPA → MPA → Reactive state → Router → DI
      .description
        p.m-b-1
          | This section provides practical examples of how to use the ecosystem in real-world scenarios,
          | covering both SPA and MPA application patterns. The examples demonstrate how the runtime,
          | build system and templates work together to create scalable frontend architectures.
        p.m-b-1
          | You can explore how to bootstrap applications, configure routing and implement reactive state
          | management without relying on heavy frameworks. SPA examples highlight component-based
          | architecture, dependency injection and lifecycle handling powered by the runtime engine.
          | MPA examples focus on lightweight setups with manual initialization and direct DOM bindings.
        p.m-b-1
          | Each example is designed to show how different parts of the system can be used independently
          | or combined depending on project requirements. The comparison between SPA and MPA approaches
          | helps to understand trade-offs in terms of complexity, performance and scalability. Special
          | attention is given to the reactive data flow and how state changes propagate to the DOM.
        p.m-b-1
          | These examples serve as a reference for building both simple pages and complex applications.
          | The goal is to provide clear, minimal and production-oriented patterns that can be adapted
          | to different use cases. By studying these examples, developers can quickly understand how to
          | structure their projects and apply the ecosystem effectively.

  section.section.m-b-4
    .container(data-animate='fade-up' data-animate-delay='200')
      h2.title-h2.m-b-4 SPA Example
      p.title-h5.m-b-2
        | Full application powered by runtime: router, DI, lifecycle and reactive state
      .card.m-b-2
        +code('ts', 'app.ts', true)
          | import { bootstrapApplication, provideRouter } from '@razerspine/runtime';
          |
          | bootstrapApplication({
          |   providers: [
          |     provideRouter([
          |       { path: '/', component: HomePage }
          |     ])
          |   ]
          | });
      .card.m-b-2
        +code('ts', 'component.ts', true)
          | export class HomePage extends BaseComponent {
          |   increment() {
          |     this.setState({ count: this.state.count + 1 });
          |   }
          | }

  section.section.m-b-4
    .container(data-animate='fade-down' data-animate-delay='200')
      h2.title-h2.m-b-4 Router & Guards
      .card.m-b-2
        +code('ts', 'routes.ts', true)
          | const routes = [
          |   { path: '/', component: HomePage },
          |   { path: '/dashboard', component: DashboardPage, canActivate: [authGuard] }
          | ];

      .card.m-b-2
        +code('ts', 'guard.ts', true)
          | const authGuard = () => {
          |   return isLoggedIn ? true : '/login';
          | };

  section.section.m-b-4
    .container(data-animate='fade-up' data-animate-delay='200')
      h2.title-h2.m-b-4 MPA Example
      p.title-h5.m-b-2
        | Lightweight reactive page without router and component system
      .card.m-b-2
        +code('ts', 'home.ts', true)
          | const { state } = createStore(
          |   { title: 'Hello MPA', count: 0 },
          |   () => update()
          | );
          |
          | function update() {
          |   applyBindings(document.body, state);
          | }
      .card.m-b-2
        +code('pug', 'template.pug', false)
          | h1(data-bind="title")
          | button(data-click="increment") +
          | span(data-bind="count")

  section.section.m-b-4
    .container(data-animate='fade-left' data-animate-delay='200')
      h2.title-h2.m-b-4 SPA vs MPA
      .card
        +code('text', 'Comparison', false)
          | SPA → Router + Components + Lifecycle (automatic)
          | MPA → Manual setup + no router + independent pages

  section.section.m-b-4
    .container(data-animate='fade-right' data-animate-delay='200')
      h2.title-h2.m-b-4 Reactivity Flow
      .card
        +code('text', 'Flow', false)
          | createStore → Proxy → state change → applyBindings → DOM update

  section.section.m-b-4
    .container(data-animate='fade-up' data-animate-delay='200')
      h2.title-h2.m-b-4 Template System
      .card.m-b-2
        +code('text', 'Templates', false)
          | SPA + SCSS + TS → spa-pug-scss-ts
          | MPA + LESS + JS → mpa-pug-less-js
      p.title-h5.slate-500
        | Templates are resolved automatically based on CLI flags

  section.section
    .container(data-animate='fade-down' data-animate-delay='200')
      h2.title-h2.m-b-4 Getting Started
      .card
        p.title-h5.m-b-2
          | To create a new project using the CLI, follow the quick start guide.

        a.link.btn.btn--outline.btn--medium(href='/cli.html')
          | Open CLI Guide
          svg.button-icon.icon--icon-small(role='img')
            use(xlink:href='#icon-arrow-next' href='#icon-arrow-next')
