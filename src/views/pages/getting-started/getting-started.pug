extends @views/layout/index.pug
include @views/mixins/code.pug

block variables
  - title = 'Getting Started - Frontend tooling ecosystem';

append style
  link(rel='stylesheet' href='./style.scss')

block content
  section.section.m-b-4
    .container
      h1.title-h1.m-b-2.text-gradient-deep.text-center Getting Started
      p.title-h5.slate-500.m-b-2.text-center
        | Learn how to create and run your first project using the Razerspine ecosystem
      p.title-h6.brand-500.text-center
        | CLI → Templates → Runtime → Build system

  section.section.m-b-4
    .container
      h2.title-h2.m-b-4 Installation
      .card
        p.m-b-2
          | You can create a new project using the CLI without installing anything globally.

        .card.card--code-block.m-b-2
          +code('block')
            | npx @razerspine/create-app my-app

        p.slate-500
          | The CLI will guide you through project setup using interactive prompts.

  section.section.m-b-4
    .container
      h2.title-h2.m-b-4 Create Application
      .card.card--padding
        p.title-h6.m-b-2
          | Interactive mode allows you to choose application type, styles and scripts.

        .card.card--code-block.m-b-2
          +code('block')
            | npx @razerspine/create-app my-app

        p.title-h6.m-b-2
          | For CI or automation, you can use non-interactive mode:

        .card.card--code-block.m-b-2
          +code('bash', 'Terminal')
            | npx @razerspine/create-app my-app \
            |   --app-type spa \
            |   --style scss \
            |   --script ts \
            |   --no-install

  section.section.m-b-4
    .container
      h2.title-h2.m-b-4 Project Structure
      .card.card--padding
        p.title-h6.m-b-2
          | Generated projects follow a predictable and scalable structure.
        .card.card--code-block.m-b-2
          +code('block')
            | src/
            |   app/
            |   pages/
            |   shared/
            |   assets/
            |   styles/
        p.slate-500
          | Each part of the application is separated to keep architecture clean and maintainable.

  section.section.m-b-4
    .container
      h2.title-h2.m-b-4 Application Types
      .row.row--gap-25
        .col-12.col-md-6
          .card
            h3.title-h4.m-b-2.text-gradient-soft SPA
            p
              | Single Page Applications use the runtime engine
              | for routing, state management and component lifecycle.
            p.slate-500.m-t-1
              | Best for dashboards and dynamic applications.

        .col-12.col-md-6
          .card
            h3.title-h4.m-b-2.text-gradient-soft MPA
            p
              | Multi Page Applications use independent pages
              | generated by webpack entry points.
            p.slate-500.m-t-1
              | Best for landing pages and static websites.

  section.section.m-b-4
    .container
      h2.title-h2.m-b-3 How It Works
      .card
        p.title-h6.m-b-2
          | The CLI uses a pipeline-based system to generate fully configured projects.
        .card.card--code-block.m-b-2
          +code('text-inline') resolve template → scaffold project → install deps → run dev

  section.section.m-b-4
    .container
      h2.title-h2.m-b-4 Build & Runtime
      .row.row--gap-25
        .col-12.col-md-6
          .card
            h3.title-h4.m-b-2.text-gradient-soft Build System
            p
              | Projects are powered by @razerspine/build,
              | a modular webpack abstraction with defineConfig API
              | and plugin-based architecture.

        .col-12.col-md-6
          .card
            h3.title-h4.m-b-2.text-gradient-soft Runtime Engine
            p
              | SPA projects use @razerspine/runtime
              | which provides DI container, router,
              | reactive state and component lifecycle.

  section.section
    .container
      h2.title-h2.m-b-4 Next Steps
      .row.row--gap-25
        .col-12.col-md-4
          .card.card--space-between
            h3.title-h4.m-b-2.text-gradient-soft Templates
            p.m-b-2 Explore available project templates
            a.link.btn.btn--outline.btn--medium(href='/templates.html') Open
              svg.button-icon.icon--icon-small(role='img')
                use(xlink:href='#icon-arrow-next' href='#icon-arrow-next')

        .col-12.col-md-4
          .card.card--space-between
            h3.title-h4.m-b-2.text-gradient-soft Runtime
            p.m-b-2 Learn how the runtime engine works
            a.link.btn.btn--outline.btn--medium(href='/runtime.html') Open
              svg.button-icon.icon--icon-small(role='img')
                use(xlink:href='#icon-arrow-next' href='#icon-arrow-next')

        .col-12.col-md-4
          .card.card--space-between
            h3.title-h4.m-b-2.text-gradient-soft Build System
            p.m-b-2 Deep dive into build configuration
            a.link.btn.btn--outline.btn--medium(href='/build.html') Open
              svg.button-icon.icon--icon-small(role='img')
                use(xlink:href='#icon-arrow-next' href='#icon-arrow-next')
