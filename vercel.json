{
  "cleanUrls": true,
  "trailingSlash": false,

  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {"key": "Cache-Control", "value": "public, max-age=31536000, immutable"}
      ]
    }
  ],

  "routes": [
    {"handle": "filesystem"},
    {"src": "/(.*)", "status": 404, "dest": "/404.html"}
  ]
}
